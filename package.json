{
  "name": "slsv-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "slsv — simple local-AWS serverless framework (monorepo)",
  "scripts": {
    "build": "pnpm -r build",
    "link:cli": "pnpm --filter @slsv/sdk build && pnpm --filter slsv build:link",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint && oxlint .",
    "format": "oxfmt . '!**/.tokensave/**'",
    "format:check": "oxfmt --check . '!**/.tokensave/**'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  }
}
