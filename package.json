{
  "name": "slsv-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "slsv — simple local-AWS serverless framework (monorepo)",
  "scripts": {
    "build": "pnpm -r build",
    "link:cli": "pnpm --filter @slsv/sdk build && pnpm --filter @slsv/cli build:link",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint && oxlint .",
    "format": "oxfmt . '!**/.tokensave/**'",
    "format:check": "oxfmt --check . '!**/.tokensave/**'",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && pnpm -r publish --access public --no-git-checks",
    "docs:schema": "tsx scripts/docs/schema.ts",
    "docs:cli": "tsx scripts/docs/cli.ts",
    "docs:sdk": "tsx scripts/docs/sdk.ts",
    "build:docs": "tsx scripts/docs/build.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4.19.2",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.7.0",
    "commander": "^15.0.0"
  }
}
