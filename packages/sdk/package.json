{
  "name": "@slsv/sdk",
  "version": "0.1.1",
  "description": "Cloud-agnostic SDK for slsv apps — write once, run on any cloud",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincentri/slsv.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "format": "oxfmt .",
    "format:check": "oxfmt --check ."
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/client-secrets-manager": "^3.1090.0",
    "@aws-sdk/client-sqs": "^3.1090.0",
    "@aws-sdk/lib-dynamodb": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1090.0",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "mysql2": "^3.23.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
