{
  "name": "slsv",
  "version": "0.1.0",
  "description": "Simple local-AWS serverless framework",
  "type": "module",
  "files": [
    "dist",
    "templates"
  ],
  "bin": {
    "slsv": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "build:link": "npm run build && npm link",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.0.0",
    "@aws-sdk/client-cloudfront": "^3.1075.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-elasticache": "^3.700.0",
    "@aws-sdk/client-eventbridge": "^3.0.0",
    "@aws-sdk/client-iam": "^3.0.0",
    "@aws-sdk/client-lambda": "^3.0.0",
    "@aws-sdk/client-rds": "^3.700.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-sqs": "^3.0.0",
    "@clack/prompts": "^0.7.0",
    "@slsv/sdk": "workspace:*",
    "adm-zip": "^0.5.10",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "esbuild": "^0.20.0",
    "mysql2": "^3.11.5",
    "pg": "^8.13.1",
    "yaml": "^2.4.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
