{
  "name": "@slsv/cli",
  "version": "0.1.3",
  "description": "Simple local-AWS serverless framework",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vincentri/slsv.git",
    "directory": "packages/cli"
  },
  "bin": {
    "slsv": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup",
    "build:link": "npm run build && npm link --force",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-acm": "^3.1090.0",
    "@aws-sdk/client-apigatewayv2": "^3.1090.0",
    "@aws-sdk/client-cloudfront": "^3.1090.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1090.0",
    "@aws-sdk/client-dynamodb": "^3.1090.0",
    "@aws-sdk/client-elasticache": "^3.1090.0",
    "@aws-sdk/client-eventbridge": "^3.1090.0",
    "@aws-sdk/client-iam": "^3.1090.0",
    "@aws-sdk/client-lambda": "^3.1090.0",
    "@aws-sdk/client-rds": "^3.1090.0",
    "@aws-sdk/client-s3": "^3.1090.0",
    "@aws-sdk/client-secrets-manager": "^3.1090.0",
    "@aws-sdk/client-sqs": "^3.1090.0",
    "@clack/prompts": "^1.7.0",
    "@slsv/sdk": "workspace:*",
    "adm-zip": "^0.6.0",
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "mysql2": "^3.23.0",
    "pg": "^8.22.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
