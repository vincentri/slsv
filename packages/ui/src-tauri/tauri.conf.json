{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "slsv UI",
  "version": "0.0.1",
  "identifier": "dev.slsv.ui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "slsv UI",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "createUpdaterArtifacts": true,
    "resources": {
      "../dist-server/**/*": "dist-server/"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/vincentri/slsv/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4Mjg5RENFNTRGRDJGMkUKUldRdUwvMVV6cDBvV0U4cVZIbVRWaUE1bzRtTHNQNm9VVkhLVmRtOERhamFKbk9haG9aTkFOR1gK"
    }
  }
}
